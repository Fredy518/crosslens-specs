        },
        "card_ref": {
          "default": "",
          "title": "Card Ref",
          "type": "string"
        },
        "rule_ref": {
          "default": "",
          "title": "Rule Ref",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "evidence_refs": {
