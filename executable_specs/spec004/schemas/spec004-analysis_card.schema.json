{
  "$defs": {
    "ConstraintExport": {
      "additionalProperties": false,
      "properties": {
        "export_type": {
          "$ref": "#/$defs/ExportType"
        },
        "export_ref": {
          "minLength": 1,
          "title": "Export Ref",
          "type": "string"
        },
        "evidence_ref": {
          "minLength": 1,
          "title": "Evidence Ref",
          "type": "string"
        },
        "value_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value Path"
        },
        "determinism_level": {
          "$ref": "#/$defs/DeterminismLevel"
        },
        "can_support_hard_constraint": {
          "title": "Can Support Hard Constraint",
          "type": "boolean"
        },
        "allowed_constraint_types": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Constraint Types",
          "type": "array"
        },
        "fact_value": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fact Value"
        },
        "label_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label Value"
        }
      },
      "required": [
        "export_type",
        "export_ref",
        "evidence_ref",
        "determinism_level",
        "can_support_hard_constraint",
        "allowed_constraint_types"
      ],
      "title": "ConstraintExport",
      "type": "object"
    },
    "DataFreshness": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date",
          "title": "As Of",
          "type": "string"
        },
        "oldest_evidence_as_of": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Oldest Evidence As Of"
        },
        "newest_evidence_as_of": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Newest Evidence As Of"
        },
        "freshness_level": {
          "anyOf": [
            {
              "$ref": "#/$defs/FreshnessLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "staleness_risk": {
          "anyOf": [
            {
              "$ref": "#/$defs/StalenessRisk"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "valid_until": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid Until"
        }
      },
      "required": [
        "as_of"
      ],
      "title": "DataFreshness",
      "type": "object"
    },
    "DataQuality": {
      "enum": [
        "high",
        "medium",
        "low",
        "unavailable",
        "unknown"
      ],
      "title": "DataQuality",
      "type": "string"
    },
    "DeterminismLevel": {
      "enum": [
        "computed",
        "structured",
        "interpreted"
      ],
      "title": "DeterminismLevel",
      "type": "string"
    },
    "Domain": {
      "enum": [
        "macro_meso",
        "fundamentals",
        "company_event",
        "sentiment",
        "technical_market"
      ],
      "title": "Domain",
      "type": "string"
    },
    "DomainStatus": {
      "enum": [
        "completed",
        "partial",
        "error",
        "unavailable"
      ],
      "title": "DomainStatus",
      "type": "string"
    },
    "EvidenceCoverage": {
      "additionalProperties": false,
      "properties": {
        "supporting_evidence_count": {
          "minimum": 0,
          "title": "Supporting Evidence Count",
          "type": "integer"
        },
        "opposing_evidence_count": {
          "minimum": 0,
          "title": "Opposing Evidence Count",
          "type": "integer"
        },
        "missing_required_evidence": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Missing Required Evidence",
          "type": "array"
        }
      },
      "required": [
        "supporting_evidence_count",
        "opposing_evidence_count"
      ],
      "title": "EvidenceCoverage",
      "type": "object"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "evidence_type": {
          "default": "",
          "title": "Evidence Type",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "determinism_level": {
          "anyOf": [
            {
              "$ref": "#/$defs/DeterminismLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "evidence_id"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "ExportType": {
      "enum": [
        "metric",
        "fact",
        "label"
      ],
      "title": "ExportType",
      "type": "string"
    },
    "FreshnessLevel": {
      "enum": [
        "real_time",
        "intraday",
        "daily",
        "quarterly",
        "event_based",
        "static"
      ],
      "title": "FreshnessLevel",
      "type": "string"
    },
    "StalenessRisk": {
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ],
      "title": "StalenessRisk",
      "type": "string"
    },
    "Stance": {
      "enum": [
        "positive",
        "moderately_positive",
        "neutral",
        "mixed",
        "moderately_negative",
        "negative",
        "unavailable",
        "not_applicable"
      ],
      "title": "Stance",
      "type": "string"
    },
    "TimeHorizonBucket": {
      "enum": [
        "intraday",
        "short_term",
        "medium_term",
        "long_term",
        "unknown"
      ],
      "title": "TimeHorizonBucket",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "card_id": {
      "minLength": 1,
      "title": "Card Id",
      "type": "string"
    },
    "schema_version": {
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "task_id": {
      "minLength": 1,
      "title": "Task Id",
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "domain": {
      "$ref": "#/$defs/Domain"
    },
    "domain_status": {
      "$ref": "#/$defs/DomainStatus"
    },
    "summary": {
      "default": "",
      "title": "Summary",
      "type": "string"
    },
    "stance": {
      "anyOf": [
        {
          "$ref": "#/$defs/Stance"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "confidence": {
      "default": 0.0,
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "confidence_reason": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Confidence Reason",
      "type": "array"
    },
    "time_horizon": {
      "default": "",
      "title": "Time Horizon",
      "type": "string"
    },
    "time_horizon_bucket": {
      "anyOf": [
        {
          "$ref": "#/$defs/TimeHorizonBucket"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "time_horizon_days_min": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Time Horizon Days Min"
    },
    "time_horizon_days_max": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Time Horizon Days Max"
    },
    "data_quality": {
      "$ref": "#/$defs/DataQuality"
    },
    "data_freshness": {
      "anyOf": [
        {
          "$ref": "#/$defs/DataFreshness"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "evidence_coverage": {
      "anyOf": [
        {
          "$ref": "#/$defs/EvidenceCoverage"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "supporting_evidence": {
      "default": [],
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "title": "Supporting Evidence",
      "type": "array"
    },
    "opposing_evidence": {
      "default": [],
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "title": "Opposing Evidence",
      "type": "array"
    },
    "key_findings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Key Findings",
      "type": "array"
    },
    "key_risks": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Key Risks",
      "type": "array"
    },
    "invalidating_conditions": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Invalidating Conditions",
      "type": "array"
    },
    "constraint_exports": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ConstraintExport"
      },
      "title": "Constraint Exports",
      "type": "array"
    },
    "domain_payload": {
      "additionalProperties": true,
      "default": {},
      "title": "Domain Payload",
      "type": "object"
    },
    "warnings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    },
    "limitations": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    }
  },
  "required": [
    "card_id",
    "schema_version",
    "task_id",
    "run_id",
    "domain",
    "domain_status",
    "data_quality",
    "created_at"
  ],
  "title": "AnalysisCard",
  "type": "object"
}