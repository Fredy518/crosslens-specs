{
  "$defs": {
    "DeterminismLevel": {
      "enum": [
        "computed",
        "structured",
        "interpreted"
      ],
      "title": "DeterminismLevel",
      "type": "string"
    },
    "ExportType": {
      "enum": [
        "metric",
        "fact",
        "label"
      ],
      "title": "ExportType",
      "type": "string"
    },
    "RegistrationStatus": {
      "description": "Governance status for constraint_exports (SPEC-004 §9.1 / SPEC-005 §6.4).",
      "enum": [
        "registered",
        "unregistered_mvp_local",
        "proposed"
      ],
      "title": "RegistrationStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "allowed_constraint_types": {
      "items": {
        "type": "string"
      },
      "title": "Allowed Constraint Types",
      "type": "array"
    },
    "can_support_hard_constraint": {
      "title": "Can Support Hard Constraint",
      "type": "boolean"
    },
    "determinism_level": {
      "$ref": "#/$defs/DeterminismLevel"
    },
    "evidence_ref": {
      "minLength": 1,
      "title": "Evidence Ref",
      "type": "string"
    },
    "export_ref": {
      "minLength": 1,
      "title": "Export Ref",
      "type": "string"
    },
    "export_type": {
      "$ref": "#/$defs/ExportType"
    },
    "fact_value": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fact Value"
    },
    "label_value": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Label Value"
    },
    "lineage_constraint_failure": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "If lineage check failed for a registered metric, reason for soft-only downgrade",
      "title": "Lineage Constraint Failure"
    },
    "registration_status": {
      "$ref": "#/$defs/RegistrationStatus",
      "default": "registered",
      "description": "Governance status: controls Hard Constraint eligibility"
    },
    "value_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Value Path"
    }
  },
  "required": [
    "export_type",
    "export_ref",
    "evidence_ref",
    "determinism_level",
    "can_support_hard_constraint",
    "allowed_constraint_types"
  ],
  "title": "ConstraintExport",
  "type": "object"
}
